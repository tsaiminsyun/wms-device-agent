{
  "name": "wms-device-agent",
  "version": "0.1.0",
  "description": "本機裝置代理：以 WebSocket / HTTP 將掃碼槍、電子秤等設備訊號轉給 WMS 網頁端；離線時退回系統鍵盤模擬（交警模式）。",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0",
    "@nut-tree-fork/nut-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
