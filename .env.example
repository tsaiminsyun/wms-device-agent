# wms-device-agent 環境變數（皆為選用，未設定則用程式內預設值）
# 複製成 .env 或直接由系統環境變數提供。

# HTTP / WebSocket 服務綁定（預設只綁本機，勿改成 0.0.0.0 對外）
HOST=127.0.0.1
PORT=8788

# 允許連線的網頁來源（Origin 白名單，逗號分隔）。瀏覽器頁面的 Origin 必須在此清單內。
WMS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 是否允許「無 Origin」的連線（非瀏覽器工具，如 wscat / 自動化測試）。正式環境建議 false。
ALLOW_NO_ORIGIN=true

# 是否啟用鍵盤模擬退路（交警模式）。設 0 則完全不打鍵盤、掃碼只走 WS（無認領時直接丟棄）。
KEYBOARD_ENABLED=1

# log 等級：debug | info | warn | error
LOG_LEVEL=info
