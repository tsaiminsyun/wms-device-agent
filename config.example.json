{
  "$comment": "把此檔複製成 config.json 放在執行目錄即可覆寫預設值；環境變數（PORT/HOST/...）的優先序高於此檔。",
  "server": {
    "host": "127.0.0.1",
    "port": 8788,
    "wsPath": "/ws"
  },
  "security": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://twwms.daigobang.com"
    ],
    "allowNoOrigin": true
  },
  "scanner": {
    "enabled": true,
    "vendorIds": ["05e0"],
    "baudRate": 9600,
    "path": null,
    "keyboardFallback": true
  },
  "hidScanner": {
    "$comment": "HID-POS/IBM/SNAPI 模式掃碼槍（node-hid）。usagePages 空=接受該廠牌任何非鍵盤/滑鼠 collection；要限定可填如 [\"0x8c\"]（0x8c=條碼掃描器）。鍵盤模式(usage 0x6)一律排除、node 讀不到。reportHeaderBytes 依機型可能需微調（看 debug log 的原始 report）。",
    "enabled": true,
    "vendorIds": ["05e0"],
    "usagePages": [],
    "reportHeaderBytes": 4
  },
  "scale": {
    "enabled": true,
    "baudRate": 9600,
    "vendorIds": ["1a86", "0403", "10c4", "067b"],
    "path": null
  },
  "serial": {
    "pollIntervalMs": 2000
  },
  "keyboard": {
    "enabled": true,
    "pressEnter": true
  },
  "logLevel": "info"
}
