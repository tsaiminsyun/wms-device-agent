{
  "$comment": "把此檔複製成 config.json 放在執行目錄即可覆寫預設值；環境變數（PORT/HOST/...）的優先序高於此檔。",
  "server": {
    "host": "127.0.0.1",
    "port": 8788,
    "wsPath": "/ws"
  },
  "security": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://wms.daigobang.com",
      "http://twwms.daigobang.com",
      "http://uswms.daigobang.com",
      "https://wms.daigobang.com",
      "https://twwms.daigobang.com",
      "https://uswms.daigobang.com",
      "https://beta-twwms.daigobang.com",
      "https://beta-uswms.daigobang.com",
      "https://beta-wms.daigobang.com"
    ],
    "allowNoOrigin": true
  },
  "scanner": {
    "enabled": true,
    "vendorIds": ["05e0"],
    "baudRate": 9600,
    "path": null,
    "keyboardFallback": true,
    "dedupWindowMs": 150
  },
  "hidScanner": {
    "$comment": "HID-POS/IBM 掃碼槍（node-hid）。usagePages 空=不過濾；reportHeaderBytes 依機型校準；dedupWindowMs=同條碼去重窗毫秒（0=關閉；預設 150＝只吃掉單次掃描硬體重送的重複報文，同碼刻意重掃照樣放行；連續/presentation 模式想抑制擺放狂洗才調大）。",
    "enabled": true,
    "vendorIds": ["05e0"],
    "usagePages": [],
    "reportHeaderBytes": 4,
    "dedupWindowMs": 150
  },
  "scale": {
    "enabled": true,
    "baudRate": 9600,
    "vendorIds": ["1a86", "0403", "10c4", "067b"],
    "path": null
  },
  "serial": {
    "pollIntervalMs": 2000
  },
  "keyboard": {
    "$comment": "無焦點認領時的離線鍵盤退路。paste=true 以剪貼簿整串貼上（快、不掉字）；設 false 改逐字輸入。pressEnter=貼上/輸入後補一個 Enter。",
    "enabled": true,
    "pressEnter": true,
    "paste": true
  },
  "logLevel": "info",
  "$comment_logDir": "log 檔目錄（每日日期檔 wms-agent-YYYY-MM-DD.log）。留空＝打包版寫在使用者「文件\\\\wms-device-agent\\\\logs」。可指定絕對路徑，如 C:\\\\wms-logs。",
  "logDir": ""
}
